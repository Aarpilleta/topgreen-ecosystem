# PostgreSQL database connection string (Supabase or local PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/topgreen

# Gemini API Key (obtain from Google AI Studio)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Express Server Port
PORT=5000

# WhatsApp Verification Token (for webhook handshake)
WHATSAPP_VERIFY_TOKEN=topgreen_token
